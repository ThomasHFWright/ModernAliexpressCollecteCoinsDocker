# AliExpress Login Credentials
# Replace with your actual login information
ALIEXPRESS_EMAIL=your_email@example.com
ALIEXPRESS_PASSWORD=your_password_here
# Runtime options
# true/false
HEADLESS=true

# Supported values: poland, us_east
LOCALE=poland

# true/false
USE_KOREA=false

# true/false - if true, run once daily at random time between 10:00-14:00
SCHEDULE=false
